FROM rust:1.88-bookworm

# Install Chromium for CDP rendering + build tools for BoringSSL (wreq TLS fingerprinting)
RUN apt-get update && apt-get install -y --no-install-recommends \
    chromium \
    chromium-sandbox \
    chromium-driver \
    ca-certificates \
    fonts-liberation \
    libasound2 \
    libgbm1 \
    libgtk-3-0 \
    libnss3 \
    libxss1 \
    libxtst6 \
    xdg-utils \
    cmake \
    build-essential \
    pkg-config \
    libclang-dev \
    perl \
    && rm -rf /var/lib/apt/lists/*

# Set Chrome path for chromiumoxide
ENV CHROME_PATH=/usr/bin/chromium

WORKDIR /workspace

CMD ["bash"]